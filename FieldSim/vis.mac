/run/initialize

/vis/open OGL
/vis/drawVolume
/vis/scene/add/trajectories smooth
/vis/scene/endOfEventAction accumulate

/vis/viewer/set/globalLineWidthScale 2

/vis/modeling/trajectories/create/drawByParticleID
/vis/modeling/trajectories/drawByParticleID-0/set gamma green
/vis/modeling/trajectories/drawByParticleID-0/set e- red
/vis/modeling/trajectories/drawByParticleID-0/set e+ magenta
/vis/modeling/trajectories/drawByParticleID-0/set alpha yellow

# Góc nhìn nghiêng 3D
/vis/viewer/set/viewpointThetaPhi 60 30
# ===============================================
# CÀI ĐẶT ĐỘ MẠNH ĐIỆN TRƯỜNG VÀ TỪ TRƯỜNG
# ===============================================
#/field/magValue 0.1 tesla # CẢM ỨNG TỪ 
/field/elecValue 100 volt/m   # CƯỜNG ĐỘ ĐIỆN TRƯỜNG
/field/update

# ===============================================
# VẼ MŨI TÊN TRƯỜNG TRỰC QUAN (SIÊU RÕ NÉT)
# ===============================================

# --- 1. Vẽ Điện trường (E-Field) dọc trục X ---
#/vis/set/colour white
#/vis/set/lineWidth 10
#/vis/scene/add/arrow 0 0 0 150 0 0 cm
#/vis/set/textColour white
#/vis/scene/add/text 85 8 0 cm 24 0 0 E-Field (500 V/m) #nhãn cho cường độ điện trường


# --- 2. Vẽ Từ trường (B-Field) dọc trục Y ---
/vis/set/colour white
/vis/set/lineWidth 10
/vis/scene/add/arrow 0 0 0 0 150 0 cm
/vis/set/textColour white
/vis/scene/add/text 0 85 0 cm 24 0 0 B-Field (0.1 T) #nhãn cho cảm ứng từ



/vis/viewer/flush
/run/beamOn 4
